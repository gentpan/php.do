{
	frankenphp {
		php_ini memory_limit 256M
		php_ini upload_max_filesize 20M
		php_ini post_max_size 21M
		php_ini max_execution_time 60
		php_ini session.save_path /var/lib/php/sessions
	}
}

php.do, www.php.do {
	root * /var/www/php.do
	encode gzip

	@blocked {
		path /config.php
		path /install/*
		path /.git/*
		path *.pem
		path *.env
		path *.log
	}
	respond @blocked 403

	# 旧 /panel → /admin
	redir /panel /admin 301
	redir /panel/* /admin/{http.request.uri.path.1} 301

	# 前台管理接口（论坛 PHP，不进 Laravel）
	@admin_action {
		path /admin/action.php /admin/action
	}
	handle @admin_action {
		root * /var/www/php.do
		rewrite * /admin/action.php
		php_server
	}

	# Filament / Laravel：文档根指向 admin/public，由 FrankenPHP 直接执行
	@laravel {
		path /admin* /livewire* /css/filament* /js/filament* /fonts/filament*
	}
	handle @laravel {
		root * /var/www/php.do/admin/public
		php_server {
			try_files {path} index.php
		}
	}

	@thread path_regexp thread ^/thread/([0-9]+)\.html$
	rewrite @thread /pages/thread.php?id={re.thread.1}

	@download path_regexp download ^/download/([0-9]+)$
	rewrite @download /pages/download.php?id={re.download.1}

	@api path_regexp api ^/api/([a-z-]+)$
	rewrite @api /api/{re.api.1}.php

	php_server

	request_body {
		max_size 20MB
	}
}
